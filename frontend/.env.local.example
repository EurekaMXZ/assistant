# Browser-visible Go API prefix. This value is embedded in the frontend build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Browser-visible AMap Web JS API key for `pnpm dev`/`pnpm build`. It is embedded at build time.
NEXT_PUBLIC_AMAP_JS_KEY=
# Browser-visible development Nginx proxy. Leave empty in same-origin production deployments.
NEXT_PUBLIC_AMAP_SERVICE_HOST=http://localhost:8081/_AMapService
